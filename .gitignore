# =============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments (NUNCA suba o venv!)
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# Pip
pip-log.txt
pip-delete-this-directory.txt

# Pytest
.pytest_cache/

# =============================================================================
# 🗄️ DJANGO
# =============================================================================
# Banco de dados de desenvolvimento (SQLite)
db.sqlite3
db.sqlite3-journal

# Migrations (mantenha os arquivos de migration, mas ignore backups)
*.pyc
*.pyo
*.pyd
*~

# Static files coletados (gerados por collectstatic)
staticfiles/
static_root/

# Media files (uploads de usuários - não versionar)
media/
media_root/

# Django logs
*.log

